{
  "name": "clawstation",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:watch": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:icon": "tauri icon",
    "layer-lint": "node scripts/layer-lint.js",
    "doc-check": "node scripts/doc-check.js",
    "release-gate": "node scripts/release-gate.js",
    "tauri-command-lint": "node scripts/tauri-command-lint.js",
    "hooks:install": "./scripts/install-git-hooks.sh",
    "fix:frontend": "npm run format",
    "fix:backend": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "fix": "npm run fix:frontend && npm run fix:backend",
    "codex:fix": "./scripts/codex-fix.sh all",
    "codex:fix:frontend": "./scripts/codex-fix.sh frontend",
    "codex:fix:backend": "./scripts/codex-fix.sh backend",
    "codex:fix:pre-commit": "./scripts/codex-fix.sh pre-commit",
    "check:frontend": "npm run type-check && npm run lint && npm run layer-lint && npm run doc-check && npm run release-gate && npm run tauri-command-lint && npm run test:coverage && npm run build",
    "check:backend": "cd src-tauri && cargo fmt -- --check && cargo clippy --all-targets -- -D warnings && cargo test",
    "check": "./scripts/pre-push-check.sh",
    "type-check": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@tauri-apps/cli": "^2.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "uuid": "^13.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
